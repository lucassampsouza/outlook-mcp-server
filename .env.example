# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Default / primary account
# These three variables are required for single-account setups and serve as
# the fallback when no `account` parameter is passed to a tool.
# ---------------------------------------------------------------------------

# Azure AD tenant ID  (Azure Portal > Azure Active Directory > Overview)
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Application (client) ID from your Azure App Registration
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client secret value (NOT the secret ID) — App Registration > Certificates & secrets
AZURE_CLIENT_SECRET=your-client-secret-value-here

# ---------------------------------------------------------------------------
# Additional named accounts (optional — for multi-account setups)
#
# Pattern: ACCOUNT_{NAME}_TENANT_ID / _CLIENT_ID / _CLIENT_SECRET
# The NAME becomes the `account` value you pass to tools (case-insensitive).
#
# Each named account requires its own Azure App Registration in its own tenant.
# See SETUP.md §Multi-account setup for step-by-step instructions.
# ---------------------------------------------------------------------------

# Example: a second "personal" Microsoft account in a different Azure AD tenant
# ACCOUNT_PERSONAL_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ACCOUNT_PERSONAL_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ACCOUNT_PERSONAL_CLIENT_SECRET=your-personal-secret-value-here

# Example: a "work" account (useful if renaming the default isn't enough)
# ACCOUNT_WORK_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ACCOUNT_WORK_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ACCOUNT_WORK_SECRET=your-work-secret-value-here
